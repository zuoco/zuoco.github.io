        <guid>http://localhost:1313/p/%E7%AC%AC%E4%B8%80%E8%8A%82-desklow%E5%88%9D%E6%AD%A5%E8%AE%A4%E8%AF%86/</guid>
        <description>&lt;h1 id=&#34;1-deskflowд»Ӣз»Қ&#34;&gt;1. Deskflowд»Ӣз»Қ
&lt;/h1&gt;&lt;p&gt;еңЁеӨҡеҸ°з”өи„‘дёҠе…ұдә«дёҖеҘ—й”®йј пјҢж”ҜжҢҒWindowsгҖҒLinuxгҖҒMacOSпјҢеҠҹиғҪзұ»дјјдәҺдёҖдёӘеҹәдәҺиҪҜд»¶зҡ„KVMеҲҮжҚўеҷЁпјҢеңЁдёҚеҗҢжңәеҷЁд№Ӣй—ҙж— зјқеҲҮжҚўгҖӮ жң¬дё“йўҳдёӯпјҢжҲ‘д»¬д»Ҙ1.21.2зүҲжң¬дёәдҫӢпјҢд»Ӣз»ҚдёҖдёӢиҪҜд»¶зҡ„еҠҹиғҪпјҢйЎ№зӣ®ең°еқҖ&lt;a class=&#34;link&#34; href=&#34;https://github.com/deskflow/deskflow&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;Deskflow&lt;/a&gt;гҖӮ&lt;/p&gt;
&lt;h1 id=&#34;2-еҠҹиғҪ&#34;&gt;2. еҠҹиғҪ
&lt;/h1&gt;&lt;p&gt;йҰ–ж¬ЎеҗҜеҠЁиҪҜд»¶ж—¶пјҢйңҖиҰҒйҖүжӢ©еҪ“еүҚзҡ„з”өи„‘жЁЎејҸпјҢжҳҜдҪңдёәжңҚеҠЎз«ҜиҝҳжҳҜе®ўжҲ·з«ҜпјҢз•ҢйқўеҰӮдёӢпјҡ  &lt;br&gt;
&lt;img src=&#34;http://localhost:1313/p/%E7%AC%AC%E4%B8%80%E8%8A%82-desklow%E5%88%9D%E6%AD%A5%E8%AE%A4%E8%AF%86/Deskflow.svg&#34;
	
	
	
	loading=&#34;lazy&#34;
	
	
&gt; &lt;br&gt;
жҺҘе…Ҙзү©зҗҶй”®зӣҳйј ж Үзҡ„е°ұжҳҜжңҚеҠЎз«ҜпјҢе…¶д»–з”өи„‘е°ұжҳҜе®ўжҲ·з«ҜгҖӮ&lt;/p&gt;
&lt;h1 id=&#34;3-иҪҜд»¶й…ҚзҪ®&#34;&gt;3. иҪҜд»¶й…ҚзҪ®
&lt;/h1&gt;&lt;p&gt;гҖҗEditгҖ‘&amp;ndash;&amp;gt;гҖҗPreferencesгҖ‘      &lt;br&gt;
&lt;img src=&#34;http://localhost:1313/p/%E7%AC%AC%E4%B8%80%E8%8A%82-desklow%E5%88%9D%E6%AD%A5%E8%AE%A4%E8%AF%86/%E8%BD%AF%E4%BB%B6%E9%85%8D%E7%BD%AE.png&#34;
	width=&#34;1187&#34;
	height=&#34;808&#34;
	srcset=&#34;http://localhost:1313/p/%E7%AC%AC%E4%B8%80%E8%8A%82-desklow%E5%88%9D%E6%AD%A5%E8%AE%A4%E8%AF%86/%E8%BD%AF%E4%BB%B6%E9%85%8D%E7%BD%AE_hu_60a4915809f77f8c.png 480w, http://localhost:1313/p/%E7%AC%AC%E4%B8%80%E8%8A%82-desklow%E5%88%9D%E6%AD%A5%E8%AE%A4%E8%AF%86/%E8%BD%AF%E4%BB%B6%E9%85%8D%E7%BD%AE_hu_5694d8caf994959c.png 1024w&#34;
